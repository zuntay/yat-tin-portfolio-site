---
import IconArrow from '../components/IconArrow.astro';
import SiteTopBar from '../components/SiteTopBar.astro';
import '../styles/global.css';
interface Props { title?: string; description?: string; print?: boolean; }
const { title = 'Yat Tin Lee — Multidisciplinary Designer', description = 'Portfolio of Yat Tin Lee, a multidisciplinary designer based between Hong Kong and Sydney.', print = false } = Astro.props;
const path = Astro.url.pathname;
const pageClass = path === '/' ? 'page-home' : `page-${path.split('/').filter(Boolean)[0] || 'home'}`;
const nav = [
  ['Work', '/work/'], ['About', '/about/'], ['Resume', '/resume/'], ['Links', '/links/'],
  ['Style guide', '/style-guide/'], ['Printable portfolio', '/pdf/'], ['Contact / Let’s talk', '/contact/'],
];
const mobileNav = nav.slice(0, 4).concat([nav[6]]);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class:list={[pageClass, { 'print-page': print }]}>
    <SiteTopBar path={path} />
    <button class="nav-overlay no-print" type="button" aria-label="Close navigation" tabindex="-1"></button>
    <aside class="nav-drawer no-print" id="nav-drawer" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Site navigation" inert>
      <div class="drawer-top"><a class="wordmark" href="/">YTL<span class="dot">.</span></a><button class="drawer-close" type="button" aria-label="Close navigation">Close <span>×</span></button></div>
      <nav aria-label="Primary navigation">
        {nav.map(([label, href], index) => <a class:list={{ active: path.startsWith(href.split('#')[0]) }} href={href}><span>{String(index + 1).padStart(2, '0')}</span>{label}<b><IconArrow /></b></a>)}
      </nav>
      <div class="drawer-note"><span>Hong Kong ↔ Sydney</span><p>Multidisciplinary design across products, experiences and delivery.</p></div>
    </aside>
    <nav class="mobile-bottom-nav no-print" aria-label="Mobile navigation">{mobileNav.map(([label, href]) => <a class:list={{ active: path.startsWith(href) }} href={href}>{label.split(' / ')[0]}</a>)}</nav>
    <main><slot /></main>
    <footer class="site-footer no-print">
      <div><a class="wordmark" href="/">YTL<span class="dot">.</span></a><p>Designing useful things, thoughtfully.</p><p>Based between Hong Kong and Sydney.</p></div>
      <div class="footer-contact"><a href="mailto:yattin.lee@student.uts.edu.au">yattin.lee@student.uts.edu.au</a><a href="mailto:mrsundaylee@gmail.com">mrsundaylee@gmail.com</a><a href="tel:+61422176467">(+61) 422 176 467</a></div>
      <div><a href="/work/">Selected work</a><a href="/style-guide/">Style guide</a><a href="/pdf/">Printable portfolio</a><a href="/contact/">Contact / Let’s talk</a></div>
      <p class="country-acknowledgement">I acknowledge the Gadigal of the Eora Nation, the Traditional Custodians of the land where I live, study and work in Sydney, and pay my respects to Elders past and present.</p>
      <p class="footer-note">Built light. Updated often. © {new Date().getFullYear()}</p>
    </footer>
    <script>
      const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
      const drawer = document.querySelector<HTMLElement>('.nav-drawer');
      const overlay = document.querySelector<HTMLButtonElement>('.nav-overlay');
      const closeButton = document.querySelector<HTMLButtonElement>('.drawer-close');
      let previousFocus: HTMLElement | null = null;
      const focusable = () => drawer?.querySelectorAll<HTMLElement>('a[href],button:not([disabled])') || [];
      const setDrawer = (open: boolean) => {
        if (!toggle || !drawer || !overlay) return;
        if (open) previousFocus = document.activeElement as HTMLElement;
        document.body.classList.toggle('drawer-open', open);
        toggle.setAttribute('aria-expanded', String(open));
        toggle.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
        drawer.setAttribute('aria-hidden', String(!open));
        drawer.toggleAttribute('inert', !open);
        overlay.tabIndex = open ? 0 : -1;
        if (open) requestAnimationFrame(() => focusable()[0]?.focus());
        else previousFocus?.focus();
      };
      toggle?.addEventListener('click', () => setDrawer(toggle.getAttribute('aria-expanded') !== 'true'));
      closeButton?.addEventListener('click', () => setDrawer(false));
      overlay?.addEventListener('click', () => setDrawer(false));
      drawer?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setDrawer(false)));
      document.addEventListener('keydown', (event) => {
        if (!drawer || drawer.getAttribute('aria-hidden') === 'true') return;
        if (event.key === 'Escape') { event.preventDefault(); setDrawer(false); return; }
        if (event.key !== 'Tab') return;
        const items = [...focusable()]; const first = items[0]; const last = items.at(-1);
        if (event.shiftKey && document.activeElement === first) { event.preventDefault(); last?.focus(); }
        else if (!event.shiftKey && document.activeElement === last) { event.preventDefault(); first?.focus(); }
      });
    </script>
  </body>
</html>
