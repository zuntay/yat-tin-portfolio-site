---
import BaseLayout from '../layouts/BaseLayout.astro';
const capabilities = [
  { title: 'Design', items: ['Industrial Design', 'Product Design', 'Interaction Design', 'Visual Storytelling', 'UI/UX — developing practice', 'UX Research — developing practice'] },
  { title: 'Production / Delivery', items: ['Design for Manufacturing', 'OEM / ODM project coordination', 'Production planning', 'Supplier / manufacturer communication', 'Design coordination', 'Project management'] },
  { title: 'Tools', items: ['SolidWorks', 'Fusion 360', 'KeyShot', 'Blender', 'Adobe Photoshop', 'Adobe Illustrator', 'Adobe Premiere Pro', 'Adobe After Effects', 'Final Cut Pro', 'HTML'] },
  { title: 'Languages', items: ['English', 'Mandarin', 'Cantonese'] },
];
const experiences = [
  { role: 'Industrial Designer', company: 'Hop Shing Metal & Plastic Manufactory', dates: 'July 2020 — September 2024', context: 'Manufacturing company with mainland China facilities and OEM experience in small kitchen appliances.', points: ['Redesigned products according to client requirements in OEM projects and proposed new design concepts to improve user experience.', 'Supported design for manufacturing across R&D, production planning, supplier communication, and engineering coordination.', 'Coordinated project timing across China supply chain, production line, quality team, engineers, and export-related product delivery.', 'Worked with technicians and engineers to execute production plans for high-volume products.', 'Contributed to in-house brand product development, R&D planning, and coordination.', 'Proposed and aligned with stakeholders on company website content, layout, and responsive presentation across phone, tablet, and desktop.', 'Assisted with in-house brand artwork and visual materials.'] },
  { role: 'Intern Designer', company: 'Hedgehog Design Inc.', dates: 'June 2016 — September 2016', points: ['Developed toy concepts in response to brand identity and product requirements.', 'Supported early-age toy design with attention to safety and manufacturability.', 'Created toy artwork and printed graphic materials.'] },
];
const education = ['Master of Interaction Design — current / present', 'BA (Hons) in Product Design — Technological and Higher Education Institute of Hong Kong, 2017–2019', 'HD in Product Innovation Technology — The Hong Kong Polytechnic University, 2014–2016'];
const volunteering = ['Lenny’s Mates Volunteer — Sydney, 2026', 'Animaga Sydney Volunteer — 2026', 'Supanova Sydney Photo Booth Volunteer — 2025'];
---
<BaseLayout title="Resume — Yat Tin Lee">
  <header class="page-intro resume-hero page-pad"><p class="eyebrow">Resume · Selected experience</p><h1>Experience,<br /><em>with design direction.</em></h1><p>Industrial design roots, project management experience, and a growing UX/UI research practice.</p><div class="resume-actions"><span class="button-link disabled" aria-disabled="true">Full CV PDF coming soon</span><a class="button-link" href="/work/">View selected work <span>↗</span></a><a class="button-link" href="mailto:yatintin.lee@student.uts.edu.au">Email <span>↗</span></a><a class="button-link" href="tel:+61422176467">(+61) 422 176 467 <span>↗</span></a></div></header>

  <section class="resume-profile page-pad"><p class="eyebrow">Profile</p><div><p>Multidisciplinary designer based between Hong Kong and Sydney, with five years of industrial design experience and four years of project management experience, now expanding into UI/UX and research through master’s study.</p><details class="capability-dropdown"><summary>Open capability map <span aria-hidden="true">+</span></summary><div class="capability-panel">{capabilities.map((group) => <article><h3>{group.title}</h3><ul>{group.items.map((item) => <li>{item}</li>)}</ul></article>)}</div></details></div></section>

  <section class="resume-award page-pad"><div><p class="eyebrow">01 · Selected project / award</p><span>Top Ten Finalist</span></div><div><h2>Kokuyo Design Award</h2><p>Selected as a Top Ten finalist for a product design concept developed through brainstorming, research, concept scoping, presentation boards, video, and prototype development.</p><ul><li>Developed concept from brainstorming and research into a concise A3 proposal.</li><li>Prepared presentation materials including illustration, context, and presentation board.</li><li>Created video and visual materials to communicate the product proposal.</li><li>Continued concept and prototype development after finalist selection.</li></ul></div></section>

  <section class="resume-section page-pad"><div class="resume-section-head"><p class="eyebrow">02 · Design experience</p><h2>From concept to production.</h2></div><div class="experience-timeline">{experiences.map((experience, index) => <article><div class="timeline-marker"><span>{String(index + 1).padStart(2, '0')}</span></div><div class="timeline-title"><p>{experience.dates}</p><h3>{experience.role}</h3><strong>{experience.company}</strong>{experience.context && <p>{experience.context}</p>}</div><ul>{experience.points.map((point) => <li>{point}</li>)}</ul></article>)}</div></section>

  <section class="resume-section education-section page-pad"><div class="resume-section-head"><p class="eyebrow">03 · Education</p><h2>Learning by making.</h2></div><ol class="education-list">{education.map((item, index) => <li><span>{String(index + 1).padStart(2, '0')}</span>{item}</li>)}</ol></section>

  <section class="resume-section community-media page-pad"><div class="resume-section-head"><p class="eyebrow">04 · Community + media</p><h2>Showing up and helping out.</h2></div><div class="volunteer-cards">{volunteering.map((item) => <article><h3>{item}</h3><p>Event operations, visitor support, teamwork and communication in busy public environments.</p></article>)}</div><p class="community-note">Activities included signup/check-in, queue guidance, ticket checking, visitor-facing support, and collaboration with staff, volunteers, and production teams.</p><div class="media-subsection"><p class="eyebrow">Media subsection</p><article class="media-role"><div><p>July 2024</p><h3>Video Production Crew Member</h3><strong>Black Diamond Culture Media Co., Ltd.</strong></div><ul><li>Supported communication between production parties.</li><li>Assisted with lighting setup, camera movement, and monitoring connections.</li><li>Worked as Director of Photography assistant, supporting camera setup and production schedule.</li></ul></article></div></section>

  <section class="additional-experience page-pad"><p class="eyebrow">05 · Transferable skills</p><h2>Additional experience,<br /><em>kept practical.</em></h2><div><article><h3>Korean BBQ crew member</h3><p>Customer service and fast-paced teamwork.</p></article><article><h3>Meat butchery shop assistant</h3><p>Packaging, labelling, production support, and retail/wholesale order support.</p></article><article><h3>Kitchen hand</h3><p>Food preparation and hygiene operations.</p></article></div><p>These roles strengthened reliability, teamwork, service communication, high-pressure workflow, and operational discipline.</p></section>
  <script>
    const capabilityDetails = document.querySelector<HTMLDetailsElement>('.capability-dropdown');
    const capabilityPanel = capabilityDetails?.querySelector('.capability-panel');
    capabilityPanel?.addEventListener('click', () => capabilityDetails?.removeAttribute('open'));
    document.addEventListener('click', (event) => { if (capabilityDetails?.open && !capabilityDetails.contains(event.target as Node)) capabilityDetails.removeAttribute('open'); });
    capabilityDetails?.addEventListener('keydown', (event) => { if (event.key === 'Escape') { capabilityDetails.removeAttribute('open'); capabilityDetails.querySelector('summary')?.focus(); } });
  </script>
</BaseLayout>
