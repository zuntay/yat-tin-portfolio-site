---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import WiredTagMap from '../../components/WiredTagMap.astro';
import { existsSync } from 'node:fs';
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const filters = [
  { label: 'Industrial Design', value: 'Industrial Design' },
  { label: 'Interaction Design', value: 'Interaction Design' },
  { label: 'DFM', value: 'DFM' },
  { label: 'Awarded', value: 'Award / Competition' },
  { label: 'Project Management', value: 'Project Management' },
  { label: 'UX Research', value: 'UX Research' },
];
const mugshot = '/images/profile/yat-tin-lee-mugshot.jpg';
const hasMugshot = existsSync('public/images/profile/yat-tin-lee-mugshot.jpg');
---
<BaseLayout title="Work — Yat Tin Lee">
  <div class="work-sun-field">
    <svg class="hero-rays" viewBox="0 0 1000 1000" aria-hidden="true" preserveAspectRatio="none">
      <path class="ray ink ray-detail" d="M500 815 C445 620 318 350 65 -20" />
      <path class="ray coral" d="M500 815 C470 590 405 305 300 -35" />
      <path class="ray grey dotted ray-detail" d="M500 815 C492 575 478 288 470 -30" />
      <path class="ray gold" d="M500 815 C530 575 578 275 640 -35" />
      <path class="ray cobalt medium" d="M500 815 C548 585 655 300 755 -25" />
      <path class="ray ink dotted ray-detail" d="M500 815 C595 610 715 330 850 -20" />
      <path class="ray coral thin" d="M500 815 C675 670 845 470 1030 235" />
      <path class="ray grey thin ray-detail" d="M500 815 C318 660 155 515 -30 390" />
      <path class="ray gold dotted ray-detail" d="M500 815 C385 590 285 400 190 175" />
      <path class="ray olive thin" d="M500 815 C620 605 710 425 795 185" />
      <path class="ray coral medium ray-detail" d="M500 815 C355 690 210 610 35 555" />
      <path class="ray gold medium" d="M500 815 C650 700 805 635 985 610" />
      <path class="ray grey dotted" d="M500 815 C455 655 430 500 420 330" />
      <path class="ray olive dotted ray-detail" d="M500 815 C555 655 595 505 610 345" />
      <path class="ray cobalt dotted ray-detail" d="M500 815 C710 720 875 690 1030 700" />
      <circle class="orbit coral dotted" cx="500" cy="815" r="86" />
      <circle class="orbit grey" cx="500" cy="815" r="112" />
      <circle class="orbit gold faint" cx="500" cy="815" r="142" />
      <circle class="orbit cobalt dotted faint" cx="500" cy="815" r="166" />
    </svg>
    <header class="page-intro work-intro page-pad">
      <div class="work-profile">
        {hasMugshot ? <img src={mugshot} alt="Yat Tin Lee" /> : <div class="profile-avatar" aria-label="Portrait placeholder for Yat Tin Lee"><span>YTL</span></div>}
        <div class="profile-copy"><span class="profile-label">Designer profile · Hong Kong ↔ Sydney</span><strong>Yat Tin Lee</strong><p>Multidisciplinary designer</p><small>Industrial design · Project management · UX research</small></div>
      </div>
      <p class="eyebrow">Selected work · 2022—2026</p>
      <h1>Things I’ve<br /><em>made & managed.</em></h1>
      <p>A mix of physical products, digital experiences and stories. Follow a discipline through the map or wander through them all.</p>
    </header>
    <section class="tag-map-section page-pad"><WiredTagMap filters={filters} count={projects.length} /></section>
  </div>
  <nav class="sticky-work-filters" aria-label="Sticky project filters" aria-hidden="true" inert>
    <div class="sticky-filter-inner">
      <button class="sticky-filter-core active" data-filter="all" data-label="All Work">All Work</button>
      <div class="sticky-filter-tags">
        {filters.map((filter) => <button data-filter={filter.value} data-label={filter.label}>{filter.label}</button>)}
      </div>
    </div>
  </nav>
  <section class="work-browser page-pad">
    <div class="portfolio-wall-head"><p class="eyebrow">Portfolio wall</p><p class="filter-status" aria-live="polite">Showing all {projects.length} projects</p></div>
    <div class="project-grid work-grid">{projects.map((project, index) => <ProjectCard project={project} index={index} />)}</div>
  </section>
  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const cards = document.querySelectorAll('[data-tags]');
    const status = document.querySelector('.filter-status');
    const mainFilter = document.querySelector('.sun-filter');
    const stickyFilter = document.querySelector<HTMLElement>('.sticky-work-filters');
    buttons.forEach((button) => button.addEventListener('click', () => {
      const filter = button.getAttribute('data-filter'); const label = button.getAttribute('data-label') || filter; let visible = 0;
      buttons.forEach((item) => item.classList.toggle('active', item.getAttribute('data-filter') === filter));
      cards.forEach((card) => { const show = filter === 'all' || card.getAttribute('data-tags')?.split('|').includes(filter || ''); card.toggleAttribute('hidden', !show); if (show) visible++; });
      if (status) status.textContent = filter === 'all' ? `Showing all ${visible} projects` : `Showing ${visible} project${visible === 1 ? '' : 's'} tagged “${label}”`;
    }));
    if (mainFilter && stickyFilter) {
      const observer = new IntersectionObserver(([entry]) => {
        const show = !entry.isIntersecting && entry.boundingClientRect.bottom < 96;
        stickyFilter.classList.toggle('is-visible', show);
        stickyFilter.setAttribute('aria-hidden', String(!show));
        stickyFilter.toggleAttribute('inert', !show);
      }, { rootMargin: '-72px 0px 0px 0px' });
      observer.observe(mainFilter);
    }
  </script>
</BaseLayout>
