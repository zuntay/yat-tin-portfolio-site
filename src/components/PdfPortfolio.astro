---
const { title, subtitle, projects } = Astro.props;
---
<div class="pdf-toolbar no-print"><a href="/pdf/">← PDF index</a><button onclick="window.print()">Print / Save PDF</button></div>
<article class="pdf-document">
  <section class="pdf-cover pdf-sheet"><div><p class="eyebrow">Selected portfolio · 2026</p><h1>{title}</h1><p class="pdf-lede">{subtitle}</p></div><div class="pdf-cover-bottom"><strong>Yat Tin Lee</strong><span>Multidisciplinary Designer</span><span>Hong Kong · Sydney</span></div></section>
  <section class="pdf-sheet pdf-intro"><p class="eyebrow">Profile</p><h2>Designing across products, systems and experiences.</h2><p>Yat Tin Lee is a multidisciplinary designer based between Hong Kong and Sydney, with five years of industrial design experience and four years of project management experience, now expanding into UI/UX and research.</p><div class="pdf-contact"><span>yatintin.lee@student.uts.edu.au<br />mrsundaylee@gmail.com<br />(+61) 422 176 467</span><span>Hong Kong · Sydney</span></div></section>
  {projects.map((project, index) => <section class="pdf-sheet pdf-project">
    <div class="pdf-project-head"><p class="eyebrow">{String(index + 1).padStart(2, '0')} · {project.data.projectType}</p><h2>{project.data.title}</h2><p>{project.data.summary}</p></div>
    <img src={project.data.hero} alt={project.data.placeholder ? '' : project.data.title} />
    <div class="pdf-meta"><div><span>Role</span><p>{project.data.role}</p></div><div><span>Year / status</span><p>{project.data.year} · {project.data.status}</p></div></div>
    {project.data.placeholder ? <div class="pdf-placeholder"><strong>Case study in progress</strong><p>Confirmed project details and imagery will be added in a future update.</p></div> : <div class="pdf-points">{project.data.sections.filter((s) => s.type === 'highlights')[0]?.items?.map((item) => <div><h3>{item.title}</h3><p>{item.text}</p></div>)}</div>}
  </section>)}
  <section class="pdf-sheet pdf-end"><p class="eyebrow">Thank you</p><h2>Let’s make something useful.</h2><p class="contact-placeholder">yatintin.lee@student.uts.edu.au<br />mrsundaylee@gmail.com<br />(+61) 422 176 467</p><p>Based between Hong Kong and Sydney.</p></section>
</article>
