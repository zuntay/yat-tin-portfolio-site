---
type Direction = 'up-right' | 'right' | 'left' | 'down';

interface Props {
  direction?: Direction;
  size?: number | string;
  class?: string;
  decorative?: boolean;
  title?: string;
}

const {
  direction = 'up-right',
  size = '1em',
  class: className = '',
  decorative = true,
  title,
} = Astro.props;

const sizeValue = typeof size === 'number' ? `${size}px` : size;
const paths: Record<Direction, string[]> = {
  'up-right': ['M7 17L17 7', 'M9 7h8v8'],
  right: ['M5 12h14', 'M13 6l6 6-6 6'],
  left: ['M19 12H5', 'M11 6l-6 6 6 6'],
  down: ['M12 5v14', 'M6 13l6 6 6-6'],
};
---
<svg
  class:list={['icon-arrow', `icon-arrow--${direction}`, className]}
  width={sizeValue}
  height={sizeValue}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={decorative ? 'true' : undefined}
  role={decorative ? undefined : 'img'}
  aria-label={!decorative && title ? title : undefined}
  focusable="false"
>
  {!decorative && title && <title>{title}</title>}
  {paths[direction].map((path) => <path d={path} vector-effect="non-scaling-stroke" />)}
</svg>
