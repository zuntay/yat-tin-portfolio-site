---
interface Props {
  path: string;
}

const { path } = Astro.props;
const primaryNav = [
  ['Work', '/work/'],
  ['About', '/about/'],
  ['Resume', '/resume/'],
  ['Links', '/links/'],
];
const actionNav = [
  ['Story', 'Style guide', '/style-guide/', 'story'],
  ['Print', 'Printable portfolio', '/pdf/', 'print'],
  ['Contact', 'Let’s talk', '/contact/', 'contact'],
];
const isWork = path.startsWith('/work');
---
<header class="site-topbar no-print">
  <div class="topbar-shell">
    <button class="nav-toggle topbar-menu" type="button" aria-label="Open navigation" aria-expanded="false" aria-controls="nav-drawer">
      <span class="menu-lines" aria-hidden="true"><i></i><i></i></span>
      <span class="menu-label">Menu</span>
      <strong>YTL<span class="dot">.</span></strong>
      <em aria-hidden="true"></em>
    </button>

    <nav class="topbar-primary" aria-label="Primary navigation">
      {primaryNav.map(([label, href]) => <a class:list={{ active: path.startsWith(href) }} href={href}>{label}</a>)}
    </nav>

    {isWork ? (
      <button class="topbar-work-core" type="button" data-work-core aria-label="Show all work and go to the portfolio wall">
        <span>All Work</span>
      </button>
    ) : (
      <a class="topbar-mark" href="/work/" aria-label="Go to selected work"><span>YTL</span></a>
    )}

    <nav class="topbar-actions" aria-label="Portfolio actions">
      {actionNav.map(([shortLabel, fullLabel, href, icon]) => (
        <a class:list={['topbar-action', `topbar-action-${icon}`, { active: path.startsWith(href) }]} href={href} aria-label={fullLabel}>
          <i aria-hidden="true"></i>
          <span>{shortLabel}</span>
        </a>
      ))}
    </nav>
  </div>
</header>
